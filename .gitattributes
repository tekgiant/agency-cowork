# Auto-detect text files and normalize line endings
* text=auto

# Markdown
*.md text eol=lf

# Shell scripts
*.sh text eol=lf

# PowerShell
*.ps1 text eol=crlf

# JSON
*.json text eol=lf

# Binary files — never diff or merge
*.pdf binary
*.docx binary
*.xlsx binary
*.pptx binary
*.gguf binary
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.woff binary
*.ttf binary
